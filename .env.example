APP_NAME=GatewayHub
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Coins.ph Dynamic QR API (sandbox). Do not hardcode keys in code; use env only.
# COINS_BASE_URL=https://api.9001.pl-qa.coinsxyz.me
# COINS_API_KEY=your-coins-api-key
# COINS_SECRET_KEY=your-coins-secret-key
# COINS_SOURCE=GATEWAYHUB

# Coins.ph webhook (set to true only for local/testing; never in production)
# COINS_WEBHOOK_ALLOW_DEV_BYPASS=false
# COINS_WEBHOOK_SECRET=

# Coins.ph webhook replay protection: max age in seconds (default 300 = 5 min)
# COINS_WEBHOOK_MAX_AGE=300
# COINS_GATEWAY_CLIENT_ID=
# COINS_GATEWAY_CLIENT_SECRET=
# COINS_GATEWAY_API_BASE=sandbox

# GCash webhook (set to true only for local/testing; never in production)
# GCASH_WEBHOOK_ALLOW_DEV_BYPASS=false
# GCASH_WEBHOOK_MAX_AGE=300
# GCASH_WEBHOOK_SECRET=
# GCASH_PROVIDER_MODE=native_direct
# GCASH_CLIENT_ID=
# GCASH_CLIENT_SECRET=
# GCASH_API_BASE_URL=
# GCASH_MERCHANT_ID=

# Maya webhook (set to true only for local/testing; never in production)
# MAYA_WEBHOOK_ALLOW_DEV_BYPASS=false
# MAYA_WEBHOOK_MAX_AGE=300
# MAYA_WEBHOOK_SECRET=
# MAYA_PROVIDER_MODE=native_checkout
# MAYA_CLIENT_ID=
# MAYA_CLIENT_SECRET=
# MAYA_API_BASE=sandbox

# Platform transaction fees. Formula: (gross * percentage/100) + fixed. Applied when payment becomes paid.
# PLATFORM_FEE_PERCENTAGE=1.5
# PLATFORM_FEE_FIXED=5

# Supported payment currencies (comma-separated ISO 4217 codes)
# PAYMENT_CURRENCIES=PHP,USD

# Rate limiting (requests per minute)
# RATE_LIMIT_API_MAX_ATTEMPTS=60
# RATE_LIMIT_WEBHOOKS_MAX_ATTEMPTS=200

# Demo checkout (test merchant API key; exposed to browser—use test key only)
# DEMO_API_KEY=

# Google OAuth (Sign in with Google)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"

# PayPal webhook (credentials from PayPal Developer Portal)
# PAYPAL_CLIENT_ID=
# PAYPAL_CLIENT_SECRET=
# PAYPAL_WEBHOOK_ID=
# PAYPAL_MODE=sandbox
# PAYPAL_WEBHOOK_ALLOW_DEV_BYPASS=false
# PAYPAL_WEBHOOK_MAX_AGE=300

# Wallet settlement / disbursement flow (disabled in current phase)
# SUREPAY_WALLET_SETTLEMENT_ENABLED=false
